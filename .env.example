# Public site URL — used for metadata, sitemap.xml and JSON-LD absolute URLs.
NEXT_PUBLIC_SITE_URL=https://www.cellulift.com

# --- Analytics & tracking (all optional; leave empty to disable) ---------
# Google Analytics 4 measurement ID (used only if NEXT_PUBLIC_GTM_ID is empty)
NEXT_PUBLIC_GA4_ID=
# Google Tag Manager container ID (recommended: manage GA4 + others from GTM)
NEXT_PUBLIC_GTM_ID=
# Meta (Facebook/Instagram) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=
# LinkedIn Insight Tag partner ID
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_ID=

# --- CRM integration -------------------------------------------------------
# Any webhook URL that accepts a JSON POST (HubSpot Forms API endpoint,
# Pipedrive/Zoho webhook, or a Zapier/Make.com "Catch Hook" URL). Every form
# submission on the site (devis, démo, rappel, brochure, roi, contact) is
# POSTed here in addition to being logged server-side.
CRM_WEBHOOK_URL=
